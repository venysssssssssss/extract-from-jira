JIRA_BASE_URL=https://ouvid.atlassian.net
JIRA_EMAIL=seu-email@empresa.com
JIRA_API_TOKEN=trocar-por-token-real

# Required only for Playwright fallback login
JIRA_WEB_PASSWORD=trocar-por-senha-web

OUTPUT_DIR=./output
TIMEZONE=America/Bahia
MAX_RESULTS=100
RETRY_ATTEMPTS=4
RETRY_BACKOFF_SECONDS=2
PLAYWRIGHT_HEADLESS=true
CLEAN_OUTPUT_ON_API_RUN=true
LOG_LEVEL=INFO
LOG_JSON=false
LOG_FILE=output/logs/application.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
